        User user = userMapper.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        Tenant tenant = tenantMapper.findById(user.getTenantId())
                .orElseThrow(() -> new RuntimeException("Tenant not found"));

